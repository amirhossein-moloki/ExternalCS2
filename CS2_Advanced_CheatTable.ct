  <LuaScript>
local configPath = os.getenv("USERPROFILE") .. "\\Documents\\CS2_Elite_Elite.ini"

function saveTableConfig()
    local f = io.open(configPath, "w")
    if not f then return end
    for i=0, AddressList.Count-1 do
        local r = AddressList[i]
        if r.Description:find("%[Enable/Disable%]") or r.Description:find("↳") or r.Description:find("   ") then
            f:write(r.Description .. "=" .. r.Value .. "|" .. tostring(r.Active) .. "\n")
        end
    end
    f:close()
    showMessage("Settings Saved.")
end

function loadTableConfig()
    local f = io.open(configPath, "r")
    if not f then return end
    for line in f:lines() do
        local d, v, a = line:match("([^=]+)=([^|]+)|(.+)")
        if d then
            local r = AddressList.getMemoryRecordByDescription(d)
            if r then
                r.Active = (a == "true")
                if not r.Description:find("%[Enable/Disable%]") then r.Value = v end
            end
        end
    end
    f:close()
end

function onMemRecPostActivate(m, b, s)
    if m.Description:find("%[Enable/Disable%]") then
        m.Color = s and 0x00FF00 or 0xFFFFFF
    end
    return true
end

for i=0, AddressList.Count-1 do AddressList[i].OnPostActivate = onMemRecPostActivate end

if readInteger("AutoLoad_Value") == 1 then loadTableConfig() end

print("CS2 Advanced Pro-Elite Tool v7.0 Ready.")
</LuaScript>
</CheatTable>
