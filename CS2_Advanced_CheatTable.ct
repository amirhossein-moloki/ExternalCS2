    <!-- [ SYSTEM INITIALIZATION ] -->
    <CheatEntry>
      <ID>100</ID>
      <Description>"⚙️ SYSTEM INITIALIZATION (ACTIVATE FIRST)"</Description>
      <Options moHideChildren="1"/>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]
globalalloc(AimbotFOV_Value, 4)
globalalloc(AimbotSmoothing_Value, 4)
globalalloc(AimbotBone_Value, 4)
globalalloc(TriggerDelay_Value, 4)
globalalloc(TeamCheck_Value, 4)
globalalloc(GlowColor_Value, 4)
globalalloc(AutoLoad_Value, 4)
globalalloc(RCS_Enable_Value, 4)
globalalloc(HitSound_Value, 4)

AimbotFOV_Value:
  dd (float)15.0
AimbotSmoothing_Value:
  dd (float)5.0
AimbotBone_Value:
  dd 6
TriggerDelay_Value:
  dd 10
TeamCheck_Value:
  dd 1
GlowColor_Value:
  dd FFFF0000
AutoLoad_Value:
  dd 1
RCS_Enable_Value:
  dd 1
HitSound_Value:
  dd 1

registersymbol(AimbotFOV_Value)
registersymbol(AimbotSmoothing_Value)
registersymbol(AimbotBone_Value)
registersymbol(TriggerDelay_Value)
registersymbol(TeamCheck_Value)
registersymbol(GlowColor_Value)
registersymbol(AutoLoad_Value)
registersymbol(RCS_Enable_Value)
registersymbol(HitSound_Value)

[DISABLE]
unregistersymbol(AimbotFOV_Value)
unregistersymbol(AimbotSmoothing_Value)
unregistersymbol(AimbotBone_Value)
unregistersymbol(TriggerDelay_Value)
unregistersymbol(TeamCheck_Value)
unregistersymbol(GlowColor_Value)
unregistersymbol(AutoLoad_Value)
unregistersymbol(RCS_Enable_Value)
unregistersymbol(HitSound_Value)
</AssemblerScript>
    </CheatEntry>

    <!-- [ 🎯 AIMBOT & TRIGGERBOT ] -->
    <CheatEntry>
      <ID>1000</ID>
      <Description>"🎯 AIMBOT &amp; TRIGGERBOT"</Description>
      <Options moHideChildren="1" moRecursiveSetValue="1"/>
      <Color>00FFFF</Color>
      <GroupHeader>1</GroupHeader>
      <CheatEntries>
        <CheatEntry>
          <ID>1001</ID>
          <Description>"🎯 Main Aimbot [Enable/Disable]"</Description>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end
if not aimTimer then aimTimer = createTimer() end
aimTimer.Interval = 1
aimTimer.OnTimer = function()
    if not isKeyDown(VK_LBUTTON) then return end
    local lp = readPointer("client.dll+17CAFA8")
    if not lp or lp == 0 then return end

    local myTeam = readInteger(lp + 0x3C3)
    local myPos = {
        x = readFloat(lp + 0x138),
        y = readFloat(lp + 0x138 + 4),
        z = readFloat(lp + 0x138 + 8) + 64
    }

    local angleAddr = readPointer("engine2.dll+5F60F8")
    if not angleAddr or angleAddr == 0 then return end
    local curPitch = readFloat(angleAddr)
    local curYaw = readFloat(angleAddr + 4)

    local entList = readPointer("client.dll+17D3168")
    if not entList or entList == 0 then return end

    local bestTarget = nil
    local maxFov = readFloat("AimbotFOV_Value") or 15.0
    local smoothing = readFloat("AimbotSmoothing_Value") or 1.0
    local boneId = readInteger("AimbotBone_Value") or 6

    for i=1, 64 do
        local listEntry = readPointer(entList + 8 * (i // 512) + 0x10)
        if listEntry and listEntry ~= 0 then
            local entity = readPointer(listEntry + 120 * (i % 512))
            if entity and entity ~= 0 and entity ~= lp then
                local health = readInteger(entity + 0x344)
                local team = readInteger(entity + 0x3C3)
                if health and health &gt; 0 and (team ~= myTeam or readInteger("TeamCheck_Value") == 0) then
                    -- Get Bone Position
                    local sceneNode = readPointer(entity + 0x310) -- m_pGameSceneNode
                    if sceneNode and sceneNode ~= 0 then
                      local boneArray = readPointer(sceneNode + 0x160 + 0x80) -- CSkeletonInstance + m_modelState + 0x80
                      if boneArray and boneArray ~= 0 then
                        local entPos = {
                          x = readFloat(boneArray + boneId * 32),
                          y = readFloat(boneArray + boneId * 32 + 4),
                          z = readFloat(boneArray + boneId * 32 + 8)
                        }
                        local dx = entPos.x - myPos.x
                        local dy = entPos.y - myPos.y
                        local dz = entPos.z - myPos.z
                        local targetYaw = math.deg(math.atan2(dy, dx))
                        local targetPitch = math.deg(-math.atan2(dz, math.sqrt(dx*dx + dy*dy)))

                        -- RCS
                        if readInteger("RCS_Enable_Value") == 1 then
                          local punch = { x = readFloat(lp + 0x1740), y = readFloat(lp + 0x1740 + 4) }
                          targetPitch = targetPitch - (punch.x * 2.0)
                          targetYaw = targetYaw - (punch.y * 2.0)
                        end

                        -- Smoothing logic
                        local newPitch = curPitch + (targetPitch - curPitch) / smoothing
                        local newYaw = curYaw + (targetYaw - curYaw) / smoothing

                        bestTarget = {p = newPitch, y = newYaw}
                        break
                      end
                    end
                end
            end
        end
    end

    if bestTarget then
        writeFloat(angleAddr, bestTarget.p)
        writeFloat(angleAddr + 4, bestTarget.y)
    end
end
aimTimer.Enabled = true
{$asm}
[DISABLE]
{$lua}
if aimTimer then aimTimer.Enabled = false end
{$asm}
</AssemblerScript>
        </CheatEntry>
        <CheatEntry>
          <ID>1002</ID>
          <Description>"   ↳ 🎯 Aimbot FOV"</Description>
