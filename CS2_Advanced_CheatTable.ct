{$lua}
if syntaxcheck then return end
if not bhopTimer then bhopTimer = createTimer() end
bhopTimer.Interval = 1
bhopTimer.OnTimer = function()
    if not isKeyDown(VK_SPACE) then return end
    local lp = readPointer("client.dll+17CAFA8")
    if lp and lp ~= 0 then
        local flags = readInteger(lp + 0x3EC)
        if flags and (flags &amp; 1) == 1 then
            writeInteger("client.dll+17C0000", 65537)
            sleep(10)
            writeInteger("client.dll+17C0000", 256)
        end
    end
end
bhopTimer.Enabled = true
