        </CheatEntry>
        <CheatEntry>
          <ID>1007</ID>
          <Description>"🎯 RCS (Recoil Control) [Enable/Disable]"</Description>
          <VariableType>4 Bytes</VariableType>
          <Address>RCS_Enable_Value</Address>
        </CheatEntry>
      </CheatEntries>
