        </CheatEntry>
        <CheatEntry>
          <ID>1005</ID>
          <Description>"🎯 Triggerbot [Enable/Disable]"</Description>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end
if not triggerTimer then triggerTimer = createTimer() end
triggerTimer.Interval = 5
triggerTimer.OnTimer = function()
    local lp = readPointer("client.dll+17CAFA8")
    if not lp or lp == 0 then return end
    local id = readInteger(lp + 0x13A4)
    if id and id &gt; 0 and id &lt; 64 then
        local delay = readInteger("TriggerDelay_Value") or 10
        sleep(delay)
        mouse_event(2, 0, 0, 0, 0)
        mouse_event(4, 0, 0, 0, 0)
    end
end
triggerTimer.Enabled = true
{$asm}
[DISABLE]
{$lua}
if triggerTimer then triggerTimer.Enabled = false end
{$asm}
</AssemblerScript>
        </CheatEntry>
