<Window x:Class="CS2GameHelper.Graphics.ManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Artanis's Professional RCS &amp; CS2 Helper" Height="700" Width="900"
        Background="#121212" Foreground="#E0E0E0"
        WindowStartupLocation="CenterScreen" BorderThickness="1" BorderBrush="#333333">
    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="Foreground" Value="#BBBBBB"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#2E7D32"/>
        </Style>
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#C62828"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Padding" Value="15,8"/>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- System Control Header -->
        <GroupBox Header="System Control" Grid.Row="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="5">
                    <TextBlock Text="RCS Status" FontWeight="Bold" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="10" Height="10" Fill="Red" x:Name="RcsStatusIndicator" Margin="0,0,5,0"/>
                        <TextBlock Text="Inactive" x:Name="RcsStatusText"/>
                    </StackPanel>
                    <TextBlock Text="Selected: None" x:Name="SelectedWeaponText" FontSize="10" Opacity="0.7"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5">
                    <TextBlock Text="Manual RCS" FontWeight="Bold" Margin="0,0,0,5"/>
                    <UniformGrid Columns="2">
                        <Button Content="Start" Style="{StaticResource SuccessButton}" Click="StartRcs_Click" Margin="2"/>
                        <Button Content="Stop" Style="{StaticResource DangerButton}" Click="StopRcs_Click" Margin="2"/>
                    </UniformGrid>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="5">
                    <TextBlock Text="Auto Detection" FontWeight="Bold" Margin="0,0,0,5"/>
                    <UniformGrid Columns="2">
                        <Button Content="Enable" Style="{StaticResource SuccessButton}" Click="EnableAuto_Click" Margin="2"/>
                        <Button Content="Disable" Style="{StaticResource DangerButton}" Click="DisableAuto_Click" Margin="2"/>
                    </UniformGrid>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="5">
                    <TextBlock Text="GSI Status" FontWeight="Bold" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="10" Height="10" Fill="Orange" Margin="0,0,5,0"/>
                        <TextBlock Text="Listening..."/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Main Content Tabs -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="0,10,0,0">
            <TabItem Header="Configuration">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <GroupBox Header="Active Weapon Selection">
                            <DockPanel>
                                <TextBlock Text="Current Active Weapon:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox x:Name="WeaponComboBox" SelectionChanged="WeaponComboBox_SelectionChanged" Background="#2D2D2D" Foreground="White" BorderThickness="1" BorderBrush="#444444"/>
                            </DockPanel>
                        </GroupBox>

                        <GroupBox Header="Weapon Parameters">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Sensitivity:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                                <TextBox x:Name="SensInput" Grid.Row="0" Grid.Column="1" Margin="5" Background="#2D2D2D" Foreground="White" BorderThickness="0"/>

                                <TextBlock Text="Multiplier:" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Margin="5"/>
                                <TextBox x:Name="MultInput" Grid.Row="0" Grid.Column="3" Margin="5" Background="#2D2D2D" Foreground="White" BorderThickness="0"/>

                                <TextBlock Text="Delay Divider:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                                <TextBox x:Name="DivInput" Grid.Row="1" Grid.Column="1" Margin="5" Background="#2D2D2D" Foreground="White" BorderThickness="0"/>

                                <TextBlock Text="Delay Adj (ms):" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Margin="5"/>
                                <TextBox x:Name="AdjInput" Grid.Row="1" Grid.Column="3" Margin="5" Background="#2D2D2D" Foreground="White" BorderThickness="0"/>

                                <Button Content="Save Parameters" Grid.Row="3" Grid.Column="3" Margin="5" Click="SaveParams_Click"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Additional Features">
                            <WrapPanel>
                                <CheckBox Content="Bhop" x:Name="BhopCheck" Margin="10" Foreground="White"/>
                                <CheckBox Content="Auto Strafe" x:Name="StrafeCheck" Margin="10" Foreground="White"/>
                                <CheckBox Content="Follow RCS" x:Name="FollowRcsCheck" Margin="10" Foreground="White"/>
                                <CheckBox Content="Glow ESP" x:Name="GlowCheck" Margin="10" Foreground="White"/>
                                <CheckBox Content="Backtracking" x:Name="BacktrackCheck" Margin="10" Foreground="White"/>
                            </WrapPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Visualization">
                <Grid>
                    <TextBlock Text="Recoil Pattern Visualization" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="10"/>
                    <Canvas x:Name="RecoilCanvas" Background="#0A0A0A" Margin="20,40,20,20"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
